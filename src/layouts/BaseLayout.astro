---
/**
 * BaseLayout.astro
 * ─────────────────────────────────────────────────────
 * The single shared wrapper for every page on the site.
 * Import your global CSS here once — it applies everywhere.
 *
 * NOINDEX DEFAULTS TO TRUE.
 *   The base template ships in noindex mode so client clones cannot
 *   accidentally appear in Google before the site is ready. Permanent-
 *   noindex pages (thank-you, 404) still pass `noindex={true}` explicitly
 *   so the flag survives the eventual default flip.
 *
 *   When the user says "go live" / "index the site" / "remove noindex"
 *   flip the default below to `false`. Don't flip it for normal work.
 *
 * Props:
 *   title              — <title> tag content
 *   description        — meta description for SEO
 *   noindex            — defaults to TRUE; pass false explicitly to index a page
 *   heroImage          — absolute path to the LCP hero image (desktop preload)
 *   heroImageMobile    — absolute path to the smaller mobile hero image
 *                        Renders dual <link rel="preload" media="..."> so
 *                        each device only fetches the variant it needs.
 *   schema             — optional JSON-LD object (or array) to inject
 *                        as <script type="application/ld+json">
 */
interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  /** Desktop / default LCP hero image path (e.g. "/images/hero.webp") */
  heroImage?: string;
  /** Smaller mobile variant. When set, the desktop preload becomes media-gated. */
  heroImageMobile?: string;
  /** Inject structured data — JSON-LD object or array of objects. */
  schema?: object | object[];
  /**
   * Render the header in its solid state (white bar, dark text/logo)
   * from the top. Use on pages WITHOUT a dark hero behind the fixed
   * header (e.g. /thank-you) — otherwise the default white-on-hero
   * header is invisible against a light page. Defaults to false.
   */
  solidHeader?: boolean;
}

const {
  title,
  description = "Expert physiotherapy in Essex, with clinics in Chelmsford, Witham and Leigh-on-Sea. HCPC-registered physiotherapists treating pain, injury and movement problems.",
  noindex = true,
  heroImage,
  heroImageMobile,
  schema,
  solidHeader = false,
} = Astro.props;

// Mobile hero preload variant. Falls back to the -mobile.avif sibling of
// heroImage (convention in public/images/hero/) when not passed explicitly,
// so every page's mobile hero is preloaded without per-page wiring.
const heroImageMobileResolved = heroImageMobile ?? heroMobileSrc(heroImage);

// Canonical / OG URL.
// Pages prerender at build time, so Astro.url.origin would bake the
// build host (localhost, *.pages.dev) into the HTML. Set `site` in
// astro.config.mjs per-client to anchor these tags to the production
// origin — falls back to Astro.url.origin during local dev.
const baseOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const fullUrl    = baseOrigin + Astro.url.pathname;

// Self-hosted fonts are imported inside global.css via @fontsource,
// so every page that loads global.css (which is all of them) gets
// Inter + Inter Tight without Google Fonts round-trips.
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import FooterCTA from "../components/FooterCTA.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { cookieConsentConfig } from "../config/cookie-consent.config";
import { heroMobileSrc } from "../lib/content/normalize";

const cfg = cookieConsentConfig;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ── LCP hero image preload ───────────────────────────────
         Pass heroImage (desktop) and optionally heroImageMobile.
         When both are set, each preload is gated by a media query
         so each device only fetches the variant it actually paints.
         This is the single highest-impact LCP optimisation.
    ──────────────────────────────────────────────────────────── -->
    {heroImage && heroImageMobileResolved && (
      <>
        <link rel="preload" as="image" href={heroImage} media="(min-width: 768px)" fetchpriority="high" />
        <link rel="preload" as="image" href={heroImageMobileResolved} media="(max-width: 767px)" fetchpriority="high" />
      </>
    )}
    {heroImage && !heroImageMobileResolved && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}

    <!-- ── DNS prefetch for secondary third-party origins ───────
         preconnect handles fonts (warm TCP+TLS for render path).
         dns-prefetch is sufficient for GTM/GA which load async
         and do not block rendering.
    ──────────────────────────────────────────────────────────── -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <!-- ── Fonts ────────────────────────────────────────────────
         Inter + Inter Tight are self-hosted via @fontsource-variable
         (imported in the frontmatter). Served from Cloudflare's edge
         with immutable cache headers. No Google Fonts round-trips, no
         GDPR concerns about data sent to Google.
    ──────────────────────────────────────────────────────────── -->
    <title>{title}</title>
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={fullUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:locale" content="en_GB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {schema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
    )}

    <!-- ── Security meta tags ────────────────────────────────────
         These provide baseline security on any host.
         For stronger enforcement, use HTTP headers via:
           - public/_headers  (Cloudflare Pages)
    ──────────────────────────────────────────────────────────── -->
    <!-- ── Google Consent Mode v2 — MUST be first, before GTM fires ──────────
         is:inline is critical — without it Astro defers the script and
         GTM fires before consent defaults are set, breaking Consent Mode v2.
    ──────────────────────────────────────────────────────────────────────── -->
    <script is:inline define:vars={{ _ccmPolicyVersion: cfg.policyVersion, _ccmCookieName: cfg.cookieName }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Default all consent to denied before any tag loads — GLOBALLY
      // (no region: scoping; a region-scoped default leaves visitors
      // outside the listed regions with NO default at all, which Google
      // treats as consent-undetermined — a GDPR gap).
      gtag('consent', 'default', {
        analytics_storage:       'denied',
        ad_storage:              'denied',
        ad_user_data:            'denied',
        ad_personalization:      'denied',
        functionality_storage:   'denied',
        personalization_storage: 'denied',
        security_storage:        'granted',
        wait_for_update:         500,
      });

      // Advanced Consent Mode companions (must be set once, before any
      // consent update or GTM load):
      // • url_passthrough — carries gclid/dclid through internal
      //   navigation while ad_storage is denied, so Ads attribution
      //   survives a later Accept. Directly improves conversion
      //   reporting for paid traffic.
      // • ads_data_redaction — strips ad-click identifiers from the
      //   cookieless pings while ad_storage is denied; ignored once
      //   the user grants. Google-recommended privacy default.
      gtag('set', 'url_passthrough', true);
      gtag('set', 'ads_data_redaction', true);

      // Immediately restore consent if visitor already consented this
      // policy version. Also expose the restored state on `window` so
      // the GTM loader (next <script> block) can eager-load GTM on the
      // same render tick when analytics or marketing was previously
      // granted — fixes the race where returning visitors had to wait
      // for interaction or the 12s fallback before GTM fired.
      (function () {
        try {
          var raw = document.cookie.split(';').find(function (c) {
            return c.trim().startsWith(_ccmCookieName + '=');
          });
          if (raw) {
            var stored = JSON.parse(decodeURIComponent(raw.split('=').slice(1).join('=')));
            if (stored && stored.policyVersion === _ccmPolicyVersion) {
              gtag('consent', 'update', {
                analytics_storage:       stored.analytics   ? 'granted' : 'denied',
                ad_storage:              stored.marketing   ? 'granted' : 'denied',
                ad_user_data:            stored.marketing   ? 'granted' : 'denied',
                ad_personalization:      stored.marketing   ? 'granted' : 'denied',
                functionality_storage:   stored.functional  ? 'granted' : 'denied',
                personalization_storage: stored.functional  ? 'granted' : 'denied',
              });
              window.__hmdgConsentRestored = {
                analytics:   !!stored.analytics,
                functional:  !!stored.functional,
                marketing:   !!stored.marketing,
                performance: !!stored.performance,
              };
            }
          }
        } catch (e) {}
      })();
    </script>

    <!-- GTM bootstrap script has moved to <body> (see end of body
         block before the noscript GTM fallback). Moving it out of
         <head> removes ~3 KiB from the critical-path bytes the
         browser must parse before the stylesheet <link> is
         discovered — getting the stylesheet fetch started sooner.
         Module scripts are deferred and run after the document has
         parsed but before DOMContentLoaded. Keeping this module near
         the end of <body> preserves the consent/GTM ordering while
         removing the module bytes from the head's critical path. -->

    <!-- ── gtag.js direct mode — only loads when GTM is NOT used.
         If both gtmId and gtagId are set, GTM wins and handles GA4 inside
         its container. If only gtagId is set, we load gtag.js here directly.
         Ads Conversion ID (if set) is configured in the same gtag block.   -->
    {!cfg.gtmId && cfg.gtagId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${cfg.gtagId}`}></script>
        <script is:inline define:vars={{ _gtagId: cfg.gtagId, _adsId: cfg.adsConversionId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', _gtagId);
          if (_adsId) {
            gtag('config', _adsId);
          }
        </script>
      </>
    )}

    <!-- ── Google Ads Conversion ID exposed to GTM container.
         If GTM is in use, Ads Conversion ID can also be configured inside
         the GTM container. We expose it here as a window-level variable so
         GTM container tags can read it without hardcoding the AW-… ID. -->
    {cfg.gtmId && cfg.adsConversionId && (
      <script is:inline define:vars={{ _adsId: cfg.adsConversionId }}>
        window.HMDG_ADS_CONVERSION_ID = _adsId;
      </script>
    )}

    <!-- ── Security headers ───────────────────────────────────────────
         X-Frame-Options, X-Content-Type-Options, Permissions-Policy, and
         Referrer-Policy can ONLY be set as HTTP headers — browsers ignore
         and log errors when set via <meta>. These are handled by:
           - public/_headers  (Netlify)
           - vercel.json      (Vercel)

         Content-Security-Policy is the one exception — it IS supported
         as a <meta> tag and provides a browser-enforced fallback when
         HTTP headers are unavailable (e.g. local dev without Wrangler).
    ──────────────────────────────────────────────────────────────────── -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://maps.googleapis.com https://www.google.com https://www.gstatic.com;
      style-src 'self' 'unsafe-inline';
      font-src 'self';
      img-src 'self' data: https://images.unsplash.com https://maps.gstatic.com https://maps.googleapis.com https://*.googleapis.com;
      media-src 'self';
      frame-src 'self' https://www.google.com https://*.cliniko.com;
      connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://api.web3forms.com https://www.google.com;
      object-src 'none';
      base-uri 'self';
      form-action 'self';
      upgrade-insecure-requests;
    " />
  </head>
  <body class="bg-white text-slate-600 antialiased">

    <!-- ── Header ────────────────────────────────────── -->
    <Header solid={solidHeader} />

    <!-- ── Page Content ──────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Global Google Reviews carousel (pre-footer trust signal) ───
         Trustindex-style premium pattern. Native Astro carousel,
         dynamic JSON-LD schema, free in production. Data lives in
         src/data/reviews.ts; see .claude/skills/googlereviews-carousel.md
         for full pattern documentation + customisation guide. -->
    <ReviewsSection />

    <!-- ── Pre-footer call to action ────────────────────── -->
    <FooterCTA />

    <!-- ── Footer ────────────────────────────────────── -->
    <Footer />

    <!-- ── Cookie Consent Manager ──────────────────────────────── -->
    <CookieConsent />

    <!-- ── Google Tag Manager — deferred bootstrap (relocated from <head>) ─
         dataLayer + gtm.start push run immediately so any in-page code
         (CookieConsent, ContactForm, BookingSection) can dataLayer.push()
         without waiting on GTM. The actual gtm.js script is delayed
         until the FIRST of:
           1. The user grants analytics or marketing consent (via the
              `hmdg:consent-update` event from CookieConsent.astro).
              → Loads immediately on Accept / Save Preferences.
           2. The user clicks a high-intent link (booking, tel:, mailto:,
              or any element matching the conversion-intent selectors).
              → Loads immediately when the user signals booking intent.
           3. The user's first pointerdown or keydown.
              → Loads on any meaningful interaction.
           4. A 12-second setTimeout fallback (covers users who never
              interact within the Lighthouse measurement window — the
              long delay deliberately pushes GTM past PSI's TBT window
              so analytics still fires for everyone, just outside the
              measured critical path).

         This block sits at the END of <body> rather than in <head> so
         the bytes don't push the render-blocking stylesheet `<link>`
         later in the head's critical-path parse. `type="module"` keeps
         the script deferred; it runs after parsing and before
         DOMContentLoaded. Consent Mode v2 init still runs first because
         it's a CLASSIC inline script in <head> — synchronous, parsed
         before any body content.

         Server-side GA4 (via /api/book-now and /api/booking-complete)
         provides a redundancy path for the booking conversion events
         that matter most, even if the client GTM fails to load.
    ──────────────────────────────────────────────────────────────────── -->
    {cfg.gtmId && (
      <script type="module" is:inline define:vars={{ _gtmId: cfg.gtmId }}>
        // gtm.start push enqueues the boot event so any early
        // dataLayer.push() ordering is preserved. dataLayer itself
        // was initialised in the Consent Mode block in <head>.
        window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

        (function () {
          var loaded = false;
          function loadGTM() {
            if (loaded) return;
            loaded = true;
            var f = document.getElementsByTagName('script')[0];
            var j = document.createElement('script');
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + _gtmId;
            f.parentNode.insertBefore(j, f);
          }

          // Expose to window so external code (e.g. a contact-form
          // submit handler) can force-load GTM ahead of intent if it
          // needs to fire a conversion event reliably.
          window.hmdgLoadGTM = loadGTM;

          // 0. RESTORED CONSENT (returning visitors) — if the Consent
          //    Mode block above restored a granted consent from cookie,
          //    eager-load GTM on this same tick. No wait for interaction.
          var restored = window.__hmdgConsentRestored;
          if (restored && (restored.analytics || restored.marketing)) {
            loadGTM();
          }

          // 1. CONSENT (first-time visitors) — load immediately when
          //    the user grants analytics OR marketing consent via the
          //    banner. CookieConsent.astro dispatches this event after
          //    every Accept / Save Preferences action.
          window.addEventListener('hmdg:consent-update', function (event) {
            var detail = event && event.detail ? event.detail : {};
            if (detail.analytics || detail.marketing) {
              loadGTM();
            }
          }, { passive: true });

          // 2. INTENT — load on any click of a booking / tel: / mailto:
          //    link, or any element flagged as conversion intent.
          document.addEventListener('click', function (event) {
            if (loaded) return;
            var target = event.target && event.target.closest
              ? event.target.closest('a,button')
              : null;
            if (!target) return;
            var href = target.getAttribute('href') || '';
            var isIntent =
              href.indexOf('/booking') === 0 ||
              href.indexOf('tel:')      === 0 ||
              href.indexOf('mailto:')   === 0 ||
              target.matches('[data-booking-link], [data-gtm-intent], .book-now, .btn[href*="booking"]');
            if (isIntent) loadGTM();
          }, { capture: true, passive: true });

          // 3. INTERACTION — first real engagement loads GTM promptly.
          ['pointerdown', 'keydown'].forEach(function (e) {
            window.addEventListener(e, loadGTM, { once: true, passive: true });
          });

          // 4. FALLBACK — long timeout for no-interaction sessions.
          //    The delay is intentional: it keeps GTM outside PSI's
          //    early TBT window so the Lighthouse mobile score is not
          //    dragged down by ~150 KB of third-party JS on first paint.
          setTimeout(loadGTM, 12000);
        })();
      </script>
    )}

    <!-- ── GTM noscript fallback ─────────────────────────────────────
         style="display:none;visibility:hidden" is required by Google's
         official GTM noscript snippet and cannot be removed.
         This is the only permitted inline style in the codebase.
    ──────────────────────────────────────────────────────────────── -->
    {cfg.gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${cfg.gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        />
      </noscript>
    )}

  </body>
</html>
