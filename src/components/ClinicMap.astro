---
/**
 * ClinicMap.astro
 * ─────────────────────────────────────────────────────
 * Single-location Google Map for a clinic detail page.
 *
 * Google retired the old keyless `?output=embed` iframe (it now 404s
 * and sends X-Frame-Options: SAMEORIGIN), so the only reliable Google
 * embed today is the **Maps Embed API (place mode)**, which needs a
 * free API key. We read it from `PUBLIC_GOOGLE_MAPS_API_KEY`:
 *   - key present → CLS-safe, IntersectionObserver-deferred iframe
 *     (Embed API "place" URL — loads from www.google.com, already in
 *     the CSP frame-src; the Embed API is free with no billing).
 *   - key absent  → a tidy "Open in Google Maps" facade card linking
 *     out to `mapsUrl` (never a broken iframe).
 * Add the key to `.env` (see .env.example) to switch every clinic map
 * to a live embed — no code change needed.
 */
interface Props {
  /** A ready-made Google Maps "Embed a map" iframe src (pb-format).
      Takes priority — loads from www.google.com (allowed in CSP). */
  src?: string;
  /** Address / place search query — used to build an Embed-API URL if
      no `src` and a PUBLIC_GOOGLE_MAPS_API_KEY is set. */
  query?: string;
  /** Clinic name — used for the iframe title + facade. */
  label: string;
  /** Google Maps search link — the facade's "open in maps" target. */
  mapsUrl: string;
  /** Address line shown on the facade. */
  addressLine?: string;
  /** Zoom level (16 ≈ street view) — Embed-API path only. */
  zoom?: number;
}
const { src, query, label, mapsUrl, addressLine, zoom = 16 } = Astro.props;

const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
const embedSrc =
  src ||
  (apiKey && query
    ? `https://www.google.com/maps/embed/v1/place?key=${apiKey}&q=${encodeURIComponent(query)}&zoom=${zoom}`
    : null);
---

{embedSrc ? (
  <div class="clinic-map" data-clinic-map>
    <div
      class="clinic-map-placeholder"
      data-map-src={embedSrc}
      data-map-title={`Map showing ${label}`}
    >
      <span class="clinic-map-hint" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Loading map…
      </span>
    </div>
  </div>
) : (
  <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="clinic-map clinic-map--facade">
    <span class="clinic-map-facade-inner">
      <span class="clinic-map-facade-pin" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      </span>
      <span class="clinic-map-facade-name">{label}</span>
      {addressLine && <span class="clinic-map-facade-addr">{addressLine}</span>}
      <span class="clinic-map-facade-cta">
        Open in Google Maps
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="11" x2="11" y2="3"/><polyline points="5 3 11 3 11 9"/></svg>
      </span>
    </span>
  </a>
)}

<script>
  const injectMap = (el: HTMLElement) => {
    if (el.dataset.loaded) return;
    const ph = el.querySelector<HTMLElement>('[data-map-src]');
    if (!ph) return;
    el.dataset.loaded = '1';
    const iframe = document.createElement('iframe');
    iframe.src = ph.dataset.mapSrc || '';
    iframe.title = ph.dataset.mapTitle || 'Map';
    iframe.loading = 'lazy';
    iframe.referrerPolicy = 'no-referrer-when-downgrade';
    iframe.setAttribute('allowfullscreen', '');
    iframe.className = 'clinic-map-iframe';
    ph.replaceWith(iframe);
  };

  const maps = Array.from(document.querySelectorAll<HTMLElement>('[data-clinic-map]'));
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          injectMap(entry.target as HTMLElement);
          obs.unobserve(entry.target);
        }
      });
    }, { rootMargin: '0px 0px 300px 0px' });
    maps.forEach((m) => io.observe(m));
  } else {
    maps.forEach(injectMap);
  }
</script>

<style>
  .clinic-map {
    position: relative;
    display: block;
    width: 100%;
    height: 420px;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-muted);
  }
  .clinic-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .clinic-map-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-body);
    opacity: 0.5;
  }
  .clinic-map-hint svg { width: 1.125rem; height: 1.125rem; }
  .clinic-map :global(.clinic-map-iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    filter: grayscale(1);
  }

  /* Facade (no API key) — a clean card that opens Google Maps. */
  .clinic-map--facade {
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background:
      radial-gradient(60% 80% at 85% 15%, color-mix(in srgb, var(--blue) 14%, transparent), transparent 70%),
      var(--color-muted);
  }
  .clinic-map--facade:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card);
  }
  .clinic-map-facade-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    padding: 1.5rem;
  }
  .clinic-map-facade-pin {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 9999px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    color: var(--blue-text);
    margin-bottom: 0.25rem;
  }
  .clinic-map-facade-pin svg { width: 1.5rem; height: 1.5rem; }
  .clinic-map-facade-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-headline);
  }
  .clinic-map-facade-addr {
    font-size: 0.875rem;
    color: var(--color-body);
    opacity: 0.75;
    max-width: 22rem;
  }
  .clinic-map-facade-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--blue-text);
  }
</style>
