---
/**
 * PriceCard.astro
 * ─────────────────────────────────────────────────────
 * A single clinic's treatment price list, rendered from
 * src/data/locations.ts (location.prices). Reused on the prices hub
 * (one per clinic) and each per-clinic prices page.
 */
import type { ClinicLocation } from '../lib/content/types';

interface Props {
  location: ClinicLocation;
}
const { location } = Astro.props;
---

<div class="price-card">
  <div class="price-card-head">
    <h2 class="price-card-name">{location.name}</h2>
    <p class="price-card-addr">{location.contact.addressLine2}</p>
  </div>

  <ul class="price-list">
    {location.prices.map((p) => (
      <li class="price-row">
        <span class="price-label">
          {p.label}
          {p.detail && <span class="price-detail">{p.detail}</span>}
        </span>
        <span class="price-value">{p.price}</span>
      </li>
    ))}
  </ul>

  <a href={location.clinicHref} class="price-card-link">
    View Clinic
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="2" y1="7" x2="11" y2="7"/><polyline points="7 3 11 7 7 11"/></svg>
  </a>
</div>

<style>
  .price-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.75rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .price-card-name {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-headline);
  }
  .price-card-addr {
    margin: 0.25rem 0 0;
    font-size: 0.8125rem;
    color: var(--color-body);
    opacity: 0.65;
  }

  .price-list {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--color-border);
  }
  .price-row:first-child { border-top: none; padding-top: 0; }
  .price-label {
    display: flex;
    flex-direction: column;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-headline);
  }
  .price-detail {
    margin-top: 0.125rem;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-body);
    opacity: 0.6;
  }
  .price-value {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-headline);
    white-space: nowrap;
  }

  .price-card-link {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--blue-text);
    text-decoration: none;
  }
  .price-card-link svg { transition: transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1); }
  .price-card-link:hover svg { transform: translateX(3px); }
  @media (prefers-reduced-motion: reduce) {
    .price-card-link svg { transition: none; }
  }
</style>
