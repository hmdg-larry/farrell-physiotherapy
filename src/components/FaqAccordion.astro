---
/**
 * FaqAccordion.astro
 * ─────────────────────────────────────────────────────
 * Reusable FAQ accordion (native <details name> = exclusive, no JS).
 * Used on the FAQs page and on each service detail page. Pass a unique
 * `name` per page instance so the exclusive-open grouping is scoped.
 */
interface Props {
  faqs: {
    q: string;
    a: string;
    aList?: { label: string; text: string }[];
    aListIntro?: string;
    aLinks?: { text: string; href?: string }[];
  }[];
  /** Group name for the native exclusive accordion. Unique per instance. */
  name?: string;
}
const { faqs, name = 'faq' } = Astro.props;
---

<ul class="faq-list">
  {faqs.map((f) => (
    <li>
      <details class="faq-item" name={name}>
        <summary class="faq-summary">
          <span class="faq-question">{f.q}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </span>
        </summary>
        <div class="faq-answer-wrap">
          <p class="faq-answer">{f.a}</p>
          {f.aList && f.aList.length > 0 && (
            <ul class="faq-answer-list">
              {f.aList.map((item) => (
                <li class="faq-answer-item">
                  <span class="faq-answer-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </span>
                  <span class="faq-answer-item-text"><strong>{item.label}</strong>: {item.text}</span>
                </li>
              ))}
            </ul>
          )}
          {f.aListIntro && <p class="faq-answer">{f.aListIntro}</p>}
          {f.aLinks && f.aLinks.length > 0 && (
            <ul class="faq-answer-list">
              {f.aLinks.map((item) => (
                <li class="faq-answer-item">
                  <span class="faq-answer-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </span>
                  <span class="faq-answer-item-text">
                    {item.href ? <a href={item.href}>{item.text}</a> : item.text}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </details>
    </li>
  ))}
</ul>

<style>
  .faq-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 48rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s ease;
  }
  .faq-item[open] { box-shadow: var(--shadow-raised); }

  .faq-summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--color-headline);
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::marker { content: ''; }
  .faq-summary:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-card);
  }

  .faq-icon {
    flex-shrink: 0;
    width: 1.875rem;
    height: 1.875rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: var(--beige);
    color: var(--color-headline);
    transition: transform 0.25s cubic-bezier(0.22, 0.61, 0.36, 1),
                background-color 0.2s ease, color 0.2s ease;
  }
  .faq-icon svg { width: 1rem; height: 1rem; }
  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
    background: var(--color-primary);
    color: var(--color-headline);
  }

  .faq-answer-wrap { padding: 0 1.5rem 1.4rem; }
  .faq-answer {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-body);
    max-width: 62ch;
  }
  /* List styling matches .why-choose-us-list: a circular muted badge with a
     headline-coloured tick beside each item, not a bullet marker. */
  .faq-answer-list {
    list-style: none;
    margin: 0.85rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 62ch;
  }
  .faq-answer-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .faq-answer-check {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    margin-top: 0.125rem;
    border-radius: 9999px;
    background-color: var(--color-muted);
    color: var(--color-headline);
  }
  .faq-answer-check svg { width: 0.75rem; height: 0.75rem; }
  .faq-answer-item-text {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-body);
  }
  .faq-answer-list strong { color: var(--color-headline); font-weight: 600; }
  /* Lead-in line between the answer and a following list. */
  .faq-answer + .faq-answer,
  .faq-answer-list + .faq-answer { margin-top: 0.85rem; }
  /* Linked list items — underline for affordance, site link-hover colour. */
  .faq-answer-item-text a {
    color: var(--color-headline);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .faq-answer-item-text a:hover { color: var(--color-primary-hover); }
  .faq-item[open] .faq-answer { animation: faq-reveal 0.28s ease both; }
  .faq-item[open] .faq-answer-list { animation: faq-reveal 0.28s ease both; }
  @media (prefers-reduced-motion: reduce) {
    .faq-item[open] .faq-answer-list { animation: none; }
  }
  @keyframes faq-reveal {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon { transition: none; }
    .faq-item[open] .faq-answer { animation: none; }
  }
</style>
