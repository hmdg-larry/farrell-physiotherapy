---
/**
 * Footer.astro
 * ─────────────────────────────────────────────────────
 * Global site footer. Used once in BaseLayout.astro.
 * Do NOT duplicate this component in individual pages.
 *
 * Per-client customisation:
 *   - Update clinic name, address, phone, email, opening hours
 *   - Update Quick Links and Services to match site structure
 *   - Legal pages (privacy-policy, terms-conditions, cookie-policy) must exist
 *   - Dynamic copyright year is automatic via new Date()
 *
 * ── Active-state system (MANDATORY on every nav change) ─────────
 * Footer lives on a dark background so active state MUST differ
 * visibly from hover. Design: active = white + semibold (600).
 * Hover = white + 400 weight. Default = --color-caption + 400.
 * Uses the `.footer-link` base class + `.is-active` modifier.
 * See .claude/rules/frontend.md — "Navigation Active State".
 */

const currentPath = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/';
  const norm = href.endsWith('/') ? href : href + '/';
  return currentPath === norm || currentPath === norm.slice(0, -1);
};

const isSection = (prefix: string): boolean => currentPath.startsWith(prefix);
void isSection; // reserved for future grouped footer sections

// Active state booleans — explicit to keep the checklist visible.
// Hash links skipped (they are in-page anchors, not routes).
const homeActive           = isActive('/');
const contactActive        = isActive('/contact');
const privacyActive        = isActive('/privacy-policy');
const termsActive          = isActive('/terms-conditions');
const cookieActive         = isActive('/cookie-policy');
---

<footer class="bg-[--color-headline]">

  <!-- ── Main columns ─────────────────────────────────────────── -->
  <div class="px-[--spacing-section-x] py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="flex-layout flex-layout--col gap-5">
        <a href="/" class="font-heading text-xl font-bold text-white hover:text-[--color-caption] transition-colors">
          ClinicName
        </a>
        <p class="m-0 text-sm text-[--color-caption] leading-relaxed">
          Your trusted clinic, helping patients recover faster, move better,
          and live without pain. HCPC-registered and fully insured.
        </p>
        <a href="#contact" class="btn btn-white self-start">Book Now</a>
      </div>

      <!-- Quick Links -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Quick Links
        </span>
        <nav class="flex-layout flex-layout--col gap-3" aria-label="Footer navigation">
          <a
            href="/"
            class:list={["footer-link text-sm", { "is-active": homeActive }]}
          >Home</a>
          <!-- Hash link — no is-active (anchor, not route) -->
          <a href="#services"      class="footer-link text-sm">Services</a>
          <a href="#team"          class="footer-link text-sm">Meet the Team</a>
          <a href="#testimonials"  class="footer-link text-sm">Patient Reviews</a>
          <a
            href="/contact"
            class:list={["footer-link text-sm", { "is-active": contactActive }]}
          >Contact Us</a>
        </nav>
      </div>

      <!-- Services -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Our Services
        </span>
        <nav class="flex-layout flex-layout--col gap-3" aria-label="Services navigation">
          <!-- All hash-anchor for now; switch to real routes when service pages exist -->
          <a href="#services" class="footer-link text-sm">Physiotherapy</a>
          <a href="#services" class="footer-link text-sm">Sports Injuries</a>
          <a href="#services" class="footer-link text-sm">Back &amp; Neck Pain</a>
          <a href="#services" class="footer-link text-sm">Post-Surgery Rehab</a>
          <a href="#services" class="footer-link text-sm">Injury Prevention</a>
        </nav>
      </div>

      <!-- Contact — address/tel/email are NOT footer-link (not navigation) -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Contact
        </span>
        <div class="flex-layout flex-layout--col gap-3">
          <address class="not-italic flex-layout flex-layout--col gap-1">
            <span class="text-sm text-[--color-caption]">123 High Street</span>
            <span class="text-sm text-[--color-caption]">London, UK, EC1A 1BB</span>
          </address>
          <a href="tel:02012345678"              class="text-sm text-[--color-caption] hover:text-white transition-colors">020 1234 5678</a>
          <a href="mailto:hello@clinicname.co.uk" class="text-sm text-[--color-caption] hover:text-white transition-colors">hello@clinicname.co.uk</a>
        </div>
        <div class="flex-layout flex-layout--col gap-2">
          <span class="text-xs font-semibold text-white uppercase tracking-widest">Opening Hours</span>
          <span class="text-sm text-[--color-caption]">Mon – Fri &nbsp; 8:00am – 7:00pm</span>
          <span class="text-sm text-[--color-caption]">Saturday &nbsp;&nbsp; 9:00am – 3:00pm</span>
          <span class="text-sm text-[--color-caption]">Sunday &nbsp;&nbsp;&nbsp;&nbsp; Closed</span>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ──────────────────────────────────────────── -->
  <div class="border-t border-white/10">
    <div class="px-[--spacing-section-x] py-4 flex-layout flex-layout--between gap-4">

      <!-- Copyright + credit (not navigation — plain hover styling) -->
      <div class="flex-layout items-center gap-5 flex-wrap">
        <span class="text-sm text-white/70">
          © Copyright HMDG {new Date().getFullYear()}
        </span>
        <span class="text-sm text-white/70">
          Designed &amp; Developed by
          <a
            href="https://hmdg.co.uk/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-white hover:text-white/90 transition-colors"
          >HMDG</a>
        </span>
      </div>

      <!-- Legal links — full footer-link active state treatment -->
      <nav class="flex-layout items-center gap-5 flex-wrap" aria-label="Legal">
        <a
          href="/privacy-policy"
          class:list={["footer-link text-sm", { "is-active": privacyActive }]}
        >Privacy Policy</a>
        <a
          href="/terms-conditions"
          class:list={["footer-link text-sm", { "is-active": termsActive }]}
        >Terms &amp; Conditions</a>
        <a
          href="/cookie-policy"
          class:list={["footer-link text-sm", { "is-active": cookieActive }]}
        >Cookie Policy</a>
      </nav>

    </div>
  </div>

</footer>
