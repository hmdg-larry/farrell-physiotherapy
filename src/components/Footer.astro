---
/**
 * Footer.astro
 * ─────────────────────────────────────────────────────
 * Global site footer. Used once in BaseLayout.astro.
 * Do NOT duplicate this component in individual pages.
 *
 * Per-client customisation (SANITY-READY — content lives in data files):
 *   - Clinic name, blurb, address, phone, email, hours, CTA → src/data/site.ts
 *   - Quick Links + Legal links → src/data/navigation.ts
 *   - Services column           → src/data/services.ts
 *   - Legal pages (privacy-policy, terms-conditions, cookie-policy) must exist
 *   - Dynamic copyright year is automatic via new Date()
 *   This component only renders — do not hardcode content here.
 *
 * ── Active-state system (MANDATORY on every nav change) ─────────
 * Footer sits on a light cream background (--color-muted) so active
 * state MUST differ visibly from hover. Design: active = blue-text
 * (brand colour) + semibold (600). Hover = headline. Default = body.
 * Uses the `.footer-link` base class + `.is-active` modifier.
 * See .claude/rules/frontend.md — "Navigation Active State".
 */

import { site } from '../data/site';
import { footerQuickLinks, footerLegalLinks } from '../data/navigation';
import { services } from '../data/services';
import { locations } from '../data/locations';
import { insurers } from '../data/insurers';

const currentPath = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/';
  const norm = href.endsWith('/') ? href : href + '/';
  return currentPath === norm || currentPath === norm.slice(0, -1);
};

const isSection = (prefix: string): boolean => currentPath.startsWith(prefix);
void isSection; // reserved for future grouped footer sections

// Hash links (#services) are in-page anchors, not routes — never active.
const linkActive = (href: string): boolean => href.startsWith('/') && isActive(href);
---

<footer class="bg-(--color-muted)">

  <!-- ── Clinics — three real clinics from src/data/locations.ts,
       each with its own address and its own page ────────────────── -->
  <div class="container-main pt-16 pb-12">
    <div class="flex items-baseline justify-between gap-4 flex-wrap mb-6">
      <span class="eyebrow">Our Clinics</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {locations.map((location) => (
        <a href={location.clinicHref} class:list={["footer-clinic-card", { "is-active": linkActive(location.clinicHref) }]}>
          <span class="footer-clinic-name">{location.name}</span>
          <span class="footer-clinic-address">
            {location.contact.addressLine1}<br />{location.contact.addressLine2}
          </span>
          <span class="footer-clinic-cta">
            View Clinic
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="2" y1="7" x2="11" y2="7"/><polyline points="7 3 11 7 7 11"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── Main columns ─────────────────────────────────────────── -->
  <div class="border-t border-(--color-border)">
    <div class="container-main py-12">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr] lg:gap-12">

        <!-- Get in Touch — emphasized shared phone/mobile/email from src/data/site.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="eyebrow">
          Get in Touch
        </span>
        <div class="flex flex-col gap-3">
          <a href={`tel:${site.contact.phoneTel}`} class="footer-contact">
            <span class="footer-contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span class="footer-contact-value">{site.contact.phoneDisplay}</span>
          </a>
          {site.contact.mobileTel && (
            <a href={`tel:${site.contact.mobileTel}`} class="footer-contact">
              <span class="footer-contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
              </span>
              <span class="footer-contact-value">{site.contact.mobileDisplay}<span class="footer-contact-suffix">Mobile</span></span>
            </a>
          )}
          <a href={`mailto:${site.contact.email}`} class="footer-contact">
            <span class="footer-contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <span class="footer-contact-value">{site.contact.email}</span>
          </a>
        </div>

        <!-- Insurers — logo trust strip from src/data/insurers.ts -->
        <div class="mt-2">
          <span class="eyebrow">Insurers We Work With</span>
          <ul class="footer-insurers">
            {insurers.map((insurer) => (
              <li class="footer-insurer">
                <img
                  src={`/images/insurance-logo/${insurer.file}`}
                  alt={insurer.name}
                  width="64"
                  height="64"
                  loading="lazy"
                  decoding="async"
                />
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Quick Links — from src/data/navigation.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="eyebrow">
          Quick Links
        </span>
        <nav class="flex-layout flex-layout--col gap-3" aria-label="Footer navigation">
          {footerQuickLinks.map((link) => (
            <a
              href={link.href}
              class:list={["footer-link text-[0.875rem]", { "is-active": linkActive(link.href) }]}
            >{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Services — from src/data/services.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="eyebrow">
          Our Services
        </span>
        <nav class="grid grid-cols-2 gap-x-4 gap-y-3" aria-label="Services navigation">
          {services.map((service) => (
            <a
              href={service.href}
              class:list={["footer-link text-[0.875rem]", { "is-active": linkActive(service.href) }]}
            >{service.title}</a>
          ))}
        </nav>
      </div>

      </div>
    </div>
  </div>

  <!-- ── Bottom bar ──────────────────────────────────────────── -->
  <div class="border-t border-(--color-border)">
    <div class="container-main py-4 flex-layout flex-layout--between gap-4">

      <!-- Copyright + credit (not navigation — plain hover styling) -->
      <div class="flex-layout items-center gap-5 flex-wrap">
        <span class="text-[0.875rem] text-(--color-body)/70">
          © Copyright {site.name} {new Date().getFullYear()}
        </span>
        <span class="text-[0.875rem] text-(--color-body)/70">
          Designed &amp; Developed by
          <a
            href="https://hmdg.co.uk/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-(--color-headline) hover:text-(--color-headline) transition-colors"
          >HMDG</a>
        </span>
      </div>

      <!-- Legal links — from src/data/navigation.ts; full footer-link active state treatment -->
      <nav class="flex-layout items-center gap-5 flex-wrap" aria-label="Legal">
        {footerLegalLinks.map((link) => (
          <a
            href={link.href}
            class:list={["footer-link text-[0.875rem]", { "is-active": linkActive(link.href) }]}
          >{link.label}</a>
        ))}
      </nav>

    </div>
  </div>

</footer>

<style>
  /* ── Emphasized contact (Get in Touch column) ─────────────────── */
  .footer-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  .footer-contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    color: var(--blue-text);
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .footer-contact-icon svg { width: 1.125rem; height: 1.125rem; }
  .footer-contact:hover .footer-contact-icon {
    background: var(--blue-text);
    border-color: var(--blue-text);
    color: #fff;
  }
  .footer-contact-value {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-headline);
    word-break: break-word;
    transition: color 0.2s ease;
  }
  .footer-contact:hover .footer-contact-value { color: var(--blue-text); }
  .footer-contact-suffix {
    margin-left: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-body);
    opacity: 0.55;
  }

  /* ── Clinic address cards ─────────────────────────────────────── */
  .footer-clinic-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    height: 100%;
    padding: 1.25rem 1.375rem;
    border-radius: var(--radius-card);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .footer-clinic-card:hover,
  .footer-clinic-card.is-active {
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }
  .footer-clinic-name {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-headline);
  }
  .footer-clinic-address {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-body);
  }
  .footer-clinic-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--blue-text);
  }
  .footer-clinic-cta svg { transition: transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1); }
  .footer-clinic-card:hover .footer-clinic-cta svg { transform: translateX(3px); }

  /* ── Insurer logo strip ───────────────────────────────────────── */
  .footer-insurers {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-insurer { display: inline-flex; }
  .footer-insurer img {
    width: 2.75rem;
    height: 2.75rem;
    object-fit: contain;
    opacity: 0.55;
    filter: grayscale(1);
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .footer-insurer img:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-clinic-card,
    .footer-clinic-cta svg {
      transition-duration: 0.01s !important;
      transform: none !important;
    }
  }
</style>
