---
/**
 * Footer.astro
 * ─────────────────────────────────────────────────────
 * Global site footer. Used once in BaseLayout.astro.
 * Do NOT duplicate this component in individual pages.
 *
 * Per-client customisation (SANITY-READY — content lives in data files):
 *   - Clinic name, blurb, address, phone, email, hours, CTA → src/data/site.ts
 *   - Quick Links + Legal links → src/data/navigation.ts
 *   - Services column           → src/data/services.ts
 *   - Legal pages (privacy-policy, terms-conditions, cookie-policy) must exist
 *   - Dynamic copyright year is automatic via new Date()
 *   This component only renders — do not hardcode content here.
 *
 * ── Active-state system (MANDATORY on every nav change) ─────────
 * Footer lives on a dark background so active state MUST differ
 * visibly from hover. Design: active = white + semibold (600).
 * Hover = white + 400 weight. Default = --color-caption + 400.
 * Uses the `.footer-link` base class + `.is-active` modifier.
 * See .claude/rules/frontend.md — "Navigation Active State".
 */

import { site } from '../data/site';
import { footerQuickLinks, footerLegalLinks } from '../data/navigation';
import { services } from '../data/services';
import { formatOpeningHours } from '../lib/content/normalize';

const currentPath = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/';
  const norm = href.endsWith('/') ? href : href + '/';
  return currentPath === norm || currentPath === norm.slice(0, -1);
};

const isSection = (prefix: string): boolean => currentPath.startsWith(prefix);
void isSection; // reserved for future grouped footer sections

// Hash links (#services) are in-page anchors, not routes — never active.
const linkActive = (href: string): boolean => href.startsWith('/') && isActive(href);

// Opening hours display lines — same source as contact page + JSON-LD.
const hoursLines = formatOpeningHours(site.hours);
---

<footer class="bg-[--color-headline]">

  <!-- ── Main columns ─────────────────────────────────────────── -->
  <div class="px-[--spacing-section-x] py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand — name/blurb/CTA from src/data/site.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <a href="/" class="font-heading text-xl font-bold text-white hover:text-[--color-caption] transition-colors">
          {site.name}
        </a>
        <p class="m-0 text-sm text-[--color-caption] leading-relaxed">
          {site.blurb}
        </p>
        <a href={site.bookingCta.href} class="btn btn-white self-start">{site.bookingCta.label}</a>
      </div>

      <!-- Quick Links — from src/data/navigation.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Quick Links
        </span>
        <nav class="flex-layout flex-layout--col gap-3" aria-label="Footer navigation">
          {footerQuickLinks.map((link) => (
            <a
              href={link.href}
              class:list={["footer-link text-sm", { "is-active": linkActive(link.href) }]}
            >{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Services — from src/data/services.ts -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Our Services
        </span>
        <nav class="flex-layout flex-layout--col gap-3" aria-label="Services navigation">
          {services.map((service) => (
            <a
              href={service.href}
              class:list={["footer-link text-sm", { "is-active": linkActive(service.href) }]}
            >{service.title}</a>
          ))}
        </nav>
      </div>

      <!-- Contact — from src/data/site.ts; address/tel/email are NOT footer-link (not navigation) -->
      <div class="flex-layout flex-layout--col gap-5">
        <span class="text-xs font-semibold text-white uppercase tracking-widest">
          Contact
        </span>
        <div class="flex-layout flex-layout--col gap-3">
          <address class="not-italic flex-layout flex-layout--col gap-1">
            <span class="text-sm text-[--color-caption]">{site.contact.addressLine1}</span>
            <span class="text-sm text-[--color-caption]">{site.contact.addressLine2}</span>
          </address>
          <a href={`tel:${site.contact.phoneTel}`}    class="text-sm text-[--color-caption] hover:text-white transition-colors">{site.contact.phoneDisplay}</a>
          <a href={`mailto:${site.contact.email}`}    class="text-sm text-[--color-caption] hover:text-white transition-colors">{site.contact.email}</a>
        </div>
        <div class="flex-layout flex-layout--col gap-2">
          <span class="text-xs font-semibold text-white uppercase tracking-widest">Opening Hours</span>
          {hoursLines.map((line) => (
            <span class="text-sm text-[--color-caption]">{line.days} &nbsp; {line.hours}</span>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ──────────────────────────────────────────── -->
  <div class="border-t border-white/10">
    <div class="px-[--spacing-section-x] py-4 flex-layout flex-layout--between gap-4">

      <!-- Copyright + credit (not navigation — plain hover styling) -->
      <div class="flex-layout items-center gap-5 flex-wrap">
        <span class="text-sm text-white/70">
          © Copyright HMDG {new Date().getFullYear()}
        </span>
        <span class="text-sm text-white/70">
          Designed &amp; Developed by
          <a
            href="https://hmdg.co.uk/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-white hover:text-white/90 transition-colors"
          >HMDG</a>
        </span>
      </div>

      <!-- Legal links — from src/data/navigation.ts; full footer-link active state treatment -->
      <nav class="flex-layout items-center gap-5 flex-wrap" aria-label="Legal">
        {footerLegalLinks.map((link) => (
          <a
            href={link.href}
            class:list={["footer-link text-sm", { "is-active": linkActive(link.href) }]}
          >{link.label}</a>
        ))}
      </nav>

    </div>
  </div>

</footer>
