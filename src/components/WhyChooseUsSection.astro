---
/**
 * WhyChooseUsSection.astro
 * ─────────────────────────────────────────────────────
 * Homepage "Why Choose Us" section. Layout follows the reference
 * design (heading + checklist on the left, a tall visual panel on
 * the right) — the reference's italic accent type was not carried
 * over, and its right-side panel (a translucent product-UI
 * screenshot with an overlapping blurred circle) was replaced with
 * this project's own visual language: the same solid-blue +
 * blurred-orb treatment as AboutSection's background, with a plain
 * clinic photo inset inside it instead of a fabricated dashboard.
 *
 * Checklist facts are real, already-established Farrell Physiotherapy
 * messaging reused from FooterCTA.astro's stats (50 years combined
 * experience, 3 Essex clinics, 5 insurers accepted) — not invented copy.
 *
 * Reusable via props (eyebrow / heading / points / cta) — defaults are
 * the homepage copy, so <WhyChooseUsSection /> with no props is
 * unchanged. The /about/ page reuses the same design with the practice's
 * founding principles from the live site.
 */
import { site } from '../data/site';

interface Props {
  eyebrow?: string;
  heading?: string;
  points?: string[];
  ctaText?: string;
  ctaHref?: string;
  /** Place the visual panel on the left (content on the right) at lg+. */
  imageLeft?: boolean;
  /** Photo inset inside the blue/orb visual panel. Defaults to placeholder. */
  image?: string;
  imageAlt?: string;
}
const {
  eyebrow = 'Why Choose Us',
  heading = 'Why Patients Choose Farrell Physiotherapy',
  points = [
    'HCPC-registered physiotherapists across 3 Essex clinics',
    '50+ years of combined clinical experience',
    'Accepted by 5 major insurance providers',
  ],
  ctaText = 'Book an Appointment',
  ctaHref = site.bookingCta.href,
  imageLeft = false,
  image = '/images/placeholder.webp',
  imageAlt = '',
} = Astro.props;
---

<section class="why-choose-us fourthsection bg-white">
  <div class="container-main">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">

      <div class="flex flex-col justify-center">
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="text-(--color-headline) m-0 mt-3 max-w-lg">{heading}</h2>

        <ul class="why-choose-us-list mt-8 flex flex-col gap-5">
          {points.map((item) => (
            <li class="why-choose-us-item flex items-start gap-3">
              <span class="why-choose-us-check flex items-center justify-center shrink-0" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="text-(--color-body) text-base leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>

        <a href={ctaHref} class="btn btn-default mt-10 self-start">{ctaText}</a>
      </div>

      <div class:list={["why-choose-us-visual relative rounded-(--radius-card) overflow-hidden min-h-[360px] lg:min-h-[480px] flex items-center justify-center p-6 lg:p-10", { "lg:order-first": imageLeft }]}>
        <div class="why-choose-us-orb" aria-hidden="true"></div>
        <img
          src={image}
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          width="800"
          height="900"
          class="relative z-10 w-full h-full object-cover rounded-(--radius-card) shadow-(--shadow-raised)"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .why-choose-us-check {
    width:            1.5rem;
    height:           1.5rem;
    margin-top:       0.125rem;
    border-radius:    9999px;
    background-color: var(--color-muted);
    color:            var(--color-headline);
  }

  /* Same solid-blue + blurred-orb treatment as AboutSection's
     background — reused here inside a contained visual panel instead
     of behind the whole section. */
  .why-choose-us-visual {
    background-color: var(--blue);
  }
  .why-choose-us-orb {
    filter:           blur(100px);
    pointer-events:   none;
    background-image: radial-gradient(circle, #d91e01 13.95%, #ff8100 40.41%, #ffb202 70.52%, #fabbe6 90%);
    border-radius:    100%;
    width:            22em;
    height:           22em;
    position:         absolute;
    inset:            0% auto auto 0%;
    transform:        translate(-45%, -45%);
  }
</style>
