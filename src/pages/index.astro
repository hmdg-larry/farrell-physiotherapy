---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesCarousel from '../components/ServicesCarousel.astro';
import ConditionsSection from '../components/ConditionsSection.astro';
import WhyChooseUsSection from '../components/WhyChooseUsSection.astro';
import TeamSection from '../components/TeamSection.astro';
import { site } from '../data/site';
import { locations } from '../data/locations';
import { buildOrganizationClinicJsonLd } from '../lib/content/normalize';

const heroImg = '/images/hero/home-physio.avif';

// Site-wide MedicalBusiness entity with the three Essex clinics as
// nested MedicalClinic locations (NAP + opening hours). AggregateRating
// is emitted separately by the global ReviewsSection (real reviews).
const _siteOrigin = Astro.site ? Astro.site.origin : Astro.url.origin;
const homeSchema = buildOrganizationClinicJsonLd(site, locations, _siteOrigin);

const heroFeatures = [
  { icon: 'user' as const, title: 'Personalised Care', desc: 'A programme built entirely around your goals and recovery.' },
  { icon: 'pulse' as const, title: 'Evidence-Based Treatment', desc: 'Proven techniques to restore movement, strength and confidence.' },
  { icon: 'support' as const, title: 'Dedicated Clinical Support', desc: "A HCPC-registered team that's with you at every step." },
];
---

<BaseLayout
  title={`Expert Physiotherapy in Essex — ${site.name}`}
  description="Expert physiotherapy in Essex with clinics in Chelmsford, Witham and Leigh-on-Sea. HCPC-registered physiotherapists treating back pain, sports injuries and more. Book today."
  heroImage={heroImg}
  schema={homeSchema}
>
  <Hero
    image={heroImg}
    imageAlt=""
    headline="Expert Physiotherapy in Essex"
    body="Helping you recover, rebuild and get back to life. All our clinics are now open for face-to-face and virtual consultations."
    ctaText="Book an Appointment"
    ctaHref={site.bookingCta.href}
    tagline="Built on evidence. Focused on you."
    features={heroFeatures}
  />
  <AboutSection image="/images/home-well-being.avif" />
  <ServicesCarousel />
  <ConditionsSection />
  <WhyChooseUsSection image="/images/home-why-choose-us.avif" />
  <TeamSection />
</BaseLayout>
