---
//
// index.astro — Public homepage
// ─────────────────────────────────────────────────────
// Clean scaffold for client sites. Replace the placeholder
// content below with real client-specific copy, hero image,
// services, testimonials, and booking CTA.
//
// The internal design system reference lives at:
//   src/pages/_dev/design-system.astro  (run `npm run dev:docs`)
//
// Rules in force on this page:
//   - Only global CSS classes + Tailwind tokens (no page-specific styles)
//   - All images: .webp with explicit width/height + decoding="async"
//   - Above-the-fold image: loading="eager" + fetchpriority="high"
//   - No HTML comments in the template — use JSX-style comments so nothing
//     leaks into production view-source.
//
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Your Clinic Name — Expert Care in [City]';
const description =
  'Professional clinic services delivered with care and precision. Book your appointment today.';
---

<BaseLayout title={title} description={description}>
  {/* ── Hero ──────────────────────────────────────────────
      Placeholder hero — no image required.
      When the client image is ready, swap to:
        <Hero image="/images/hero.webp" heroImage prop on BaseLayout, etc. */}
  <section
    class="relative flex flex-col justify-center bg-[--color-hero-dark] text-white min-h-svh md:min-h-[600px] lg:min-h-[640px] 2xl:max-h-[900px] overflow-hidden"
  >
    <div class="container-main relative z-10 py-24 md:py-32 lg:py-40">
      <div class="max-w-3xl">
        <span class="eyebrow text-white/70">HMDG Astro Base Template</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight">
          Replace with the client's value proposition.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl">
          This is the starting scaffold. Update the copy, add a hero image,
          and build out the services, testimonials, and booking sections.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#book" class="btn-default">Book Now</a>
          <a href="#services" class="btn-secondary">Our Services</a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Services teaser ───────────────────────────────── */}
  <section id="services" class="py-20 md:py-28 bg-[--color-white]">
    <div class="container-main">
      <div class="max-w-2xl mb-12 md:mb-16">
        <span class="eyebrow">Services</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">
          What we do
        </h2>
        <p class="mt-4 text-[--color-body] leading-relaxed">
          Replace these cards with the client's real services. Each card
          should link to a dedicated service page under <code>/services/*</code>.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {[1, 2, 3].map((n) => (
          <article class="p-8 bg-[--color-surface] rounded-[--radius-card] border border-[--color-border]">
            <h3 class="text-xl font-semibold tracking-tight">Service {n}</h3>
            <p class="mt-3 text-[--color-body] leading-relaxed">
              Short description of what this service does and who it helps.
              Two short sentences works best here.
            </p>
            <a href={`/services/service-${n}`} class="mt-5 inline-block text-[--color-primary] font-medium">
              Learn more →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── Booking CTA ───────────────────────────────────── */}
  <section id="book" class="py-20 md:py-28 bg-[--color-accent]">
    <div class="container-main text-center max-w-2xl mx-auto">
      <span class="eyebrow">Book an appointment</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">
        Ready to get started?
      </h2>
      <p class="mt-4 text-[--color-body] leading-relaxed">
        Replace with a clear conversion-focused message. One sentence is
        usually enough here — the CTA should do the work.
      </p>
      <a href="/contact" class="btn-default mt-8 inline-block">
        Book Your Appointment
      </a>
    </div>
  </section>
</BaseLayout>
