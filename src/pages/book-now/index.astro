---
/**
 * book-now/index.astro — Book Now hub
 * ─────────────────────────────────────────────────────────
 * Link target for the header CTA (a plain link, not a dropdown, per
 * user request — see src/data/navigation.ts). Mirrors the contact page's
 * visual language (navy strip + curved white card + halo, contact-row
 * icon circles) but swaps the contact form for the 3 clinics: a left
 * "book your appointment" column with the shared phone/mobile/email, and
 * a right column of per-clinic booking cards.
 *
 * Each clinic's bookingHref is the real per-location Cliniko booking URL
 * (src/data/locations.ts) — opened in a new tab.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { locations } from '../../data/locations';
import { site } from '../../data/site';

const heroImg = '/images/hero/hero-book.avif';

const phoneDisplay  = site.contact.phoneDisplay;
const phoneTel      = site.contact.phoneTel;
const mobileDisplay = site.contact.mobileDisplay;
const mobileTel     = site.contact.mobileTel;
const email         = site.contact.email;
---

<BaseLayout
  title={`Book Now — ${site.name}`}
  description={`Book an appointment at ${site.name}'s Chelmsford, Witham, or Leigh-on-Sea clinic — online or by phone.`}
  heroImage={heroImg}
>
  <PageHero
    image={heroImg}
    imageAlt=""
    eyebrow="Book Now"
    headline="Book Your Appointment"
    intro="Choose the clinic that suits you and book your appointment online in a few clicks."
    showCta={false}
    compact
  />

  <!-- ── Navy strip with white curved card ─────────────────────── -->
  <section class="booking firstsection">
    <div class="container-main">
      <div class="booking-card">
        <div class="booking-grid">

          <!-- ── Left column — intro + shared contact ────────────── -->
          <div class="booking-info">
            <span class="eyebrow">Book Now</span>
            <h2 class="booking-h2">Three Clinics Across Essex</h2>
            <p class="booking-intro">
              Every clinic uses the same online booking system, so you can
              secure your appointment in minutes. Prefer to speak to us? Call
              or email and we'll be happy to book you in.
            </p>

            <div class="booking-pill">
              <svg class="booking-pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <span>Quick & Easy Online Booking</span>
            </div>

            <ul class="booking-contact-list no-bullets">
              <li>
                <a class="booking-contact-row" href={`tel:${phoneTel}`} aria-label={`Call us on ${phoneDisplay}`}>
                  <span class="booking-icon-circle" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                  </span>
                  <div class="booking-contact-text">
                    <span class="booking-contact-label">Phone</span>
                    <span class="booking-contact-value">{phoneDisplay}</span>
                  </div>
                </a>
              </li>
              {mobileTel && (
                <li>
                  <a class="booking-contact-row" href={`tel:${mobileTel}`} aria-label={`Call our mobile on ${mobileDisplay}`}>
                    <span class="booking-icon-circle" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                        <line x1="12" y1="18" x2="12.01" y2="18"></line>
                      </svg>
                    </span>
                    <div class="booking-contact-text">
                      <span class="booking-contact-label">Mobile</span>
                      <span class="booking-contact-value">{mobileDisplay}</span>
                    </div>
                  </a>
                </li>
              )}
              <li>
                <a class="booking-contact-row" href={`mailto:${email}`} aria-label={`Send us an email at ${email}`}>
                  <span class="booking-icon-circle" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                      <polyline points="22 6 12 13 2 6"></polyline>
                    </svg>
                  </span>
                  <div class="booking-contact-text">
                    <span class="booking-contact-label">Email</span>
                    <span class="booking-contact-value">{email}</span>
                  </div>
                </a>
              </li>
            </ul>

            <div class="halo-clip" aria-hidden="true">
              <div class="halo"></div>
            </div>
          </div>

          <!-- ── Right column — clinic booking cards ─────────────── -->
          <div class="booking-clinics">
            <span class="eyebrow eyebrow-clinics">Choose Your Clinic</span>
            <ul class="booking-clinic-list no-bullets">
              {locations.map((location) => (
                <li class="booking-clinic-card">
                  <div class="booking-clinic-head">
                    <span class="booking-icon-circle" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                    </span>
                    <div class="booking-clinic-text">
                      <h3 class="booking-clinic-name">{location.name}</h3>
                      <p class="booking-clinic-addr">{location.contact.addressLine1}, {location.contact.addressLine2}</p>
                    </div>
                  </div>
                  <div class="booking-clinic-actions">
                    <a href={location.bookingHref} target="_blank" rel="noopener noreferrer" class="btn btn-default booking-clinic-cta">Book an Appointment</a>
                    <a href={location.clinicHref} class="booking-clinic-link">
                      Clinic details
                      <svg width="15" height="15" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="2" y1="7" x2="11" y2="7" />
                        <polyline points="7 3 11 7 7 11" />
                      </svg>
                    </a>
                  </div>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Section: navy strip with curved white card overlay ──────── */
  .booking {
    background-color: var(--beige);
    padding-top:    var(--spacing-section-y);
    padding-bottom: var(--spacing-section-y);
  }
  @media (min-width: 1200px) {
    .booking {
      padding-top:    var(--spacing-section-y-lg);
      padding-bottom: var(--spacing-section-y-lg);
    }
  }

  .booking-card {
    position:         relative;
    background-color: var(--color-white);
    border-radius:    1.5rem;
    padding:          2rem 1.25rem;
    box-shadow:       var(--shadow-card);
  }
  @media (min-width: 768px)  { .booking-card { padding: 2.5rem 2rem; } }
  @media (min-width: 1024px) { .booking-card { padding: 3rem; } }

  /* ── 42/58 grid (favours the clinic list on desktop) ─────────── */
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .booking-grid {
      grid-template-columns: 42fr 58fr;
      gap: 3.5rem;
      align-items: start;
    }
  }

  /* ── Left column ─────────────────────────────────────────────── */
  .booking-info { position: relative; z-index: 1; }
  .booking-h2 { margin: 0; }
  .booking-intro {
    margin: 1rem 0 0;
    color: var(--color-body);
    font-size: var(--text-base);
    max-width: 30rem;
  }

  .booking-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-badge);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-headline);
    background: var(--color-white);
  }
  .booking-pill-icon {
    width: 1rem; height: 1rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .no-bullets { list-style: none; padding: 0; margin: 0; }

  .booking-contact-list {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }
  .booking-contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-headline);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .booking-contact-row:hover { border-color: var(--color-primary); }
  @media (prefers-reduced-motion: no-preference) {
    .booking-contact-row:hover {
      box-shadow: var(--shadow-card);
      transform: translateY(-1px);
    }
  }
  .booking-contact-row:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .booking-icon-circle {
    width: 2.75rem; height: 2.75rem; min-width: 2.75rem;
    border-radius: 50%;
    background: var(--color-muted);
    color: var(--blue-text);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .booking-icon-circle svg { width: 1.25rem; height: 1.25rem; }
  .booking-contact-row:hover .booking-icon-circle,
  .booking-clinic-card:hover .booking-icon-circle {
    background: var(--color-primary);
    color: var(--color-headline);
  }

  .booking-contact-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }
  .booking-contact-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-caption);
  }
  .booking-contact-value {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-headline);
    line-height: 1.4;
    word-break: break-word;
  }

  /* ── Decorative halo ─────────────────────────────────────────── */
  .halo-clip {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    pointer-events: none;
    z-index: 0;
  }
  .halo {
    position: absolute;
    bottom: -8rem;
    left: -6rem;
    width: 24rem;
    height: 24rem;
    border-radius: 50%;
    background: var(--color-hero-dark);
    opacity: 0.045;
    filter: blur(80px);
  }

  /* ── Right column — clinic cards ─────────────────────────────── */
  .booking-clinics {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .eyebrow-clinics { margin: 0 0 0.5rem; }

  .booking-clinic-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .booking-clinic-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .booking-clinic-card:hover { border-color: var(--color-primary); }
  @media (prefers-reduced-motion: no-preference) {
    .booking-clinic-card:hover {
      box-shadow: var(--shadow-card);
      transform: translateY(-2px);
    }
  }

  .booking-clinic-head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .booking-clinic-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .booking-clinic-name {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-headline);
  }
  .booking-clinic-addr {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-body);
    line-height: 1.5;
  }

  .booking-clinic-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
  }
  @media (min-width: 480px) {
    .booking-clinic-actions { justify-content: space-between; }
  }
  .booking-clinic-cta { flex-shrink: 0; }
  .booking-clinic-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-headline);
    text-decoration: none;
  }
  .booking-clinic-link svg {
    color: var(--blue-text);
    transition: transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .booking-clinic-link:hover svg { transform: translateX(3px); }

  @media (prefers-reduced-motion: reduce) {
    .booking-contact-row,
    .booking-clinic-card,
    .booking-clinic-link svg { transition: none; }
  }
</style>
