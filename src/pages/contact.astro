---
//
// contact.astro
// ─────────────────────────────────────────────────────────
// Public contact page — uses the reusable <ContactForm /> component.
//
// The form is Web3Forms-powered. To change the inbox that receives
// submissions, update PUBLIC_WEB3FORMS_KEY in:
//   - .env                   (local dev)
//   - Cloudflare Pages       (production — Settings → Environment variables)
//
// For full setup instructions see deployment.md → Part 2: Web3Forms Setup.
//
import BaseLayout  from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Us — ClinicName"
  description="Get in touch with ClinicName. We are here to help."
>

  <section class="hero-dark">
    <div class="container-main">
      <div class="container-inner contact-inner">
        <span class="eyebrow">Get in Touch</span>
        <h1 class="text-white m-0 mt-3">Contact Us</h1>
        <p class="m-0 mt-3 text-white/60 max-w-lg leading-relaxed">
          We would love to hear from you. Reach out and a member of our team
          will get back to you as soon as possible.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-main">
      <div class="container-inner max-w-2xl mx-auto">
        <ContactForm
          subjectPrefix="Website Name"
          brandName="Website Name"
          id="contact-page"
        />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-dark {
    background-color: var(--color-hero-dark);
  }
  .contact-inner {
    padding-top:    4rem;
    padding-bottom: 4rem;
  }
</style>
