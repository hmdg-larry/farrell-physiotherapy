---
/**
 * clinics/index.astro — All Locations hub
 * ─────────────────────────────────────────────────────────
 * Links to the 3 per-location clinic pages (src/pages/clinics/[slug].astro).
 * Card design echoes the footer's clinic cards (white card, name,
 * address, "View Clinic →") but elevated for a standalone page: a
 * map-pin icon badge, a hairline divider, and a second "Directions"
 * action so it reads as a fuller card, not a copy of the footer.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { locations } from '../../data/locations';
import { site } from '../../data/site';

const heroImg = '/images/hero/hero-clinics.avif';
---

<BaseLayout
  title={`Our Clinics — ${site.name}`}
  description={`${site.name}'s clinics in Chelmsford, Witham, and Leigh-on-Sea.`}
  heroImage={heroImg}
>
  <PageHero
    image={heroImg}
    imageAlt=""
    eyebrow="Our Clinics"
    headline="Our Clinics"
    intro="Three clinics across Essex — choose the one nearest you and book your appointment today."
  />

  <section class="clinics firstsection">
    <div class="container-main">
      <div class="clinics-grid grid grid-cols-1 sm:grid-cols-3 gap-6">
        {locations.map((location) => (
          <div class="clinics-card">
            <span class="clinics-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <h2 class="clinics-card-name">{location.name}</h2>
            <p class="clinics-card-address">
              {location.contact.addressLine1}<br />{location.contact.addressLine2}
            </p>
            <div class="clinics-card-foot">
              <a href={location.clinicHref} class="clinics-card-link">
                View Clinic
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="2" y1="7" x2="11" y2="7"/><polyline points="7 3 11 7 7 11"/></svg>
              </a>
              <a href={location.contact.mapsUrl} target="_blank" rel="noopener noreferrer" class="clinics-card-directions">
                Directions
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="11" x2="11" y2="3"/><polyline points="5 3 11 3 11 9"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .clinics-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.75rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .clinics-card:hover {
    box-shadow: var(--shadow-raised);
    transform: translateY(-2px);
  }

  .clinics-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    background: var(--beige);
    color: var(--blue-text);
  }
  .clinics-card-icon svg { width: 1.25rem; height: 1.25rem; }

  .clinics-card-name {
    margin: 1.125rem 0 0;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-headline);
  }
  .clinics-card-address {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-body);
  }

  .clinics-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }
  .clinics-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--blue-text);
    text-decoration: none;
  }
  .clinics-card-link svg { transition: transform 0.2s cubic-bezier(0.22, 0.61, 0.36, 1); }
  .clinics-card:hover .clinics-card-link svg { transform: translateX(3px); }

  .clinics-card-directions {
    display: inline-flex;
    align-items: center;
    gap: 0.3125rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-body);
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .clinics-card-directions:hover {
    opacity: 1;
    color: var(--color-headline);
  }

  @media (prefers-reduced-motion: reduce) {
    .clinics-card,
    .clinics-card-link svg {
      transition: none;
    }
  }
</style>
